  "rootDir": "..",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^@toeicpass/ad-system$": "<rootDir>/../../packages/ad-system/src",
    "^@toeicpass/conversation-ai$": "<rootDir>/../../packages/conversation-ai/src"
  }
}
