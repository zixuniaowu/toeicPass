{
  "compilerOptions": {
    "target": "es2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "paths": {
      "@toeicpass/shared": ["../../packages/shared/src"],
      "@toeicpass/ad-system": ["../../packages/ad-system/src"],
      "@toeicpass/ad-system/web": ["../../packages/ad-system/web"],
      "@toeicpass/conversation-ai": ["../../packages/conversation-ai/src"],
      "@toeicpass/conversation-ai/web": ["../../packages/conversation-ai/web"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
