# API endpoint (optional, defaults to http://127.0.0.1:8001/api/v1)
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8001/api/v1

# Google OAuth Client ID (same value as GOOGLE_CLIENT_ID in API .env)
# Get from https://console.cloud.google.com/apis/credentials
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# LINE Login Channel ID (same value as LINE_CHANNEL_ID in API .env)
# Get from https://developers.line.biz/console/
# NEXT_PUBLIC_LINE_CHANNEL_ID=your-line-channel-id

# WeChat App ID (same value as WECHAT_APP_ID in API .env)
# Get from https://open.weixin.qq.com/
# NEXT_PUBLIC_WECHAT_APP_ID=your-wechat-app-id

# Umami visitor analytics
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-umami-website-id
# NEXT_PUBLIC_UMAMI_URL=https://cloud.umami.is/script.js
