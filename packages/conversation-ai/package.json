{
  "name": "@toeicpass/conversation-ai",
  "version": "1.0.0",
  "description": "Reusable AI conversation module with voice chat — backend service (Gemini AI + rule-based fallback) + React frontend component",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zixuniaowu/toeicPass.git",
    "directory": "packages/conversation-ai"
  },
  "keywords": [
    "conversation",
    "ai",
    "toeic",
    "english",
    "speaking",
    "gemini",
    "voice",
    "speech",
    "practice"
  ],
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./web": {
      "types": "./dist/web/index.d.ts",
      "default": "./dist/web/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
